 0\n","avg_humidity           0\n","avg_wind_level         0\n","dtype: int64\n","\n","3. Encoding hours_stock_status: {np.int64(0): np.int64(81123596), np.int64(1): np.int64(26876404)}\n","   - 0 = stockout? -> 75.11%\n","   - 1 = available? -> 24.89%\n","\n","4. Stockout rate (6h–22h): 78.83%\n","\n","5. Số lượng duy nhất:\n","   city_id: 18\n","   store_id: 898\n","   product_id: 865\n","   third_category_id: 233\n","\n","6. Top 10 third_category_id:\n","third_category_id\n","60     181080\n","113    160020\n","81     135720\n","103    123570\n","77     116730\n","123    110340\n","154     98910\n","168     82440\n","65      79290\n","94      78480\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","=== KẾT LUẬN ===\n","- Stockout rate 6h–22h: 78.83% → KHÔNG PHÙ HỢP với paper (~20%)\n","- Sales pattern: Peak 9h & 16h → PHÙ HỢP với paper\n","- Dữ liệu có thể là SUBSET (tập trung vào SKU thường xuyên hết hàng)\n","- Khuyến nghị: Kiểm tra source data hoặc dùng subset nhỏ hơn để test model\n"]}]},{"cell_type":"markdown","source":["#bước chạy theo paper, rerun"],"metadata":{"id":"NL2z301ZfiYQ"}},{"cell_type":"code","source":["# Cell EDA & Preprocessing for Latent Demand Recovery\n","\n","import pandas as pd\n","import numpy as np\n","import torch\n","from sklearn.preprocessing import StandardScaler\n","\n","print(\"=== BƯỚC CHUẨN BỊ DỮ LIỆU CHO LATENT DEMAND RECOVERY ===\\n\")\n","\n","# 1. Chọn 1 subset nhỏ để test model (ví dụ: 1000 dòng đầu)\n","df_sample = df_train.head(1000).copy()\n","\n","# 2. Tạo features cho mô hình\n","def create_features(row):\n","    # Lấy sales và stock status từ 6h đến 22h (17 giờ)\n","    sales_6_22 = np.array(row['hours_sale'])[6:23]\n","    stock_6_22 = np.array(row['hours_stock_status'])[6:23]\n","\n","    # Các covariate\n","    discount = row['discount']\n","    precpt = row['precpt']\n","    holiday = row['holiday_flag']\n","    activity = row['activity_flag']\n","    temp = row['avg_temperature']\n","    humidity = row['avg_humidity']\n","    wind = row['avg_wind_level']\n","\n","    # Tạo feature vector: [sales_6_22, stock_6_22, discount, precpt, ...]\n","    features = np.concatenate([\n","        sales_6_22,\n","        stock_6_22,\n","        [discount, precpt, holiday, activity, temp, humidity, wind]\n","    ])\n","\n","    return features\n","\n","# Áp dụng cho sample\n","features_list = df_sample.apply(create_features, axis=1)\n","X = np.array(features_list.tolist())  # shape: (1000, 17+17+7=41)\n","\n","# 3. Tạo target: latent demand (giả định: nếu stockout=0 → demand = sales + noise; nếu stockout=1 → demand = sales)\n","# Trong thực tế, demand thật không biết → nhưng để train, chúng ta có thể dùng \"sales\" làm target khi available, và \"sales + offset\" khi stockout.\n","# Đây là cách đơn giản để mô phỏng latent demand.\n","\n","y = []\n","for _, row in df_sample.iterrows():\n","    sales_6_22 = np.array(row['hours_sale'])[6:23]\n","    stock_6_22 = np.array(row['hours_stock_status'])[6:23]\n","\n","    # Giả định: khi stockout, demand = sales * 2 (vì có thể khách muốn mua nhiều hơn)\n","    latent_demand = np.where(stock_6_22 == 0, sales_6_22 * 2, sales_6_22)\n","    y.append(latent_demand)\n","\n","y = np.array(y)  # shape: (1000, 17)\n","\n","print(f\"X shape: {X.shape}\")\n","print(f\"y shape: {y.shape}\")\n","\n","# 4. Chuẩn hóa dữ liệu\n","scaler_X = StandardScaler()\n","X_scaled = scaler_X.fit_transform(X)\n","\n","scaler_y = StandardScaler()\n","y_scaled = scaler_y.fit_transform(y)\n","\n","print(\"\\n✅ Đã chuẩn bị xong dữ liệu cho mô hình latent demand recovery.\")\n","print(\"Tiếp theo: Xây dựng mô hình LSTM đơn giản để dự báo latent demand.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"kuVS-WN4flyO","executionInfo":{"status":"ok","timestamp":1763478246419,"user_tz":-420,"elapsed":7206,"user":{"displayName":"Tri Huynh","userId":"03244751285998314177"}},"outputId":"93d05553-0036-4899-a389-696d5daaf7a0"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["=== BƯỚC CHUẨN BỊ DỮ LIỆU CHO LATENT DEMAND RECOVERY ===\n","\n","X shape: (1000, 41)\n","y shape: (1000, 17)\n","\n","✅ Đã chuẩn bị xong dữ liệu cho mô hình latent demand recovery.\n","Tiếp theo: Xây dựng mô hình LSTM đơn giản để dự báo latent demand.\n"]}]},{"cell_type":"code","source":["# Cell: Mô hình LSTM đơn giản cho Latent Demand Recovery\n","\n","import torch\n","import torch.nn as nn\n","import torch.optim as optim\n","from torch.utils.data import DataLoader, TensorDataset\n","import numpy as np\n","\n","# 1. Chuyển dữ liệu sang tensor PyTorch\n","X_tensor = torch.tensor(X_scaled, dtype=torch.float32)  # (1000, 41)\n","y_tensor = torch.tensor(y_scaled, dtype=torch.float32)  # (1000, 17)\n","\n","# 2. Chia train/val\n","split = int(0.8 * len(X_tensor))\n","X_train, X_val = X_tensor[:split], X_tensor[split:]\n","y_train, y_val = y_tensor[:split], y_tensor[split:]\n","\n","train_loader = DataLoader(TensorDataset(X_train, y_train), batch_size=32, shuffle=True)\n","val_loader = DataLoader(TensorDataset(X_val, y_val), batch_size=32, shuffle=False)\n","\n","# 3. Định nghĩa mô hình LSTM đơn giản\n","class SimpleLSTM(nn.Module):\n","    def __init__(self, input_size=41, hidden_size=64, output_size=17, num_layers=1):\n","        super(SimpleLSTM, self).__init__()\n","        self.hidden_size = hidden_size\n","        self.num_layers = num_layers\n","\n","        # Linear layer để biến đổi input thành sequence giả\n","        self.input_proj = nn.Linear(input_size, hidden_size)\n","        # LSTM\n","        self.lstm = nn.LSTM(hidden_size, hidden_size, num_layers, batch_first=True)\n","        # Output layer\n","        self.fc = nn.Linear(hidden_size, output_size)\n","\n","    def forward(self, x):\n","        # x: (batch, 41)\n","        # Biến input thành \"sequence giả\" độ dài 17 (để khớp output)\n","        x_proj = self.input_proj(x)  # (batch, hidden_size)\n","        x_seq = x_proj.unsqueeze(1).repeat(1, 17, 1)  # (batch, 17, hidden_size)\n","\n","        lstm_out, _ = self.lstm(x_seq)  # (batch, 17, hidden_size)\n","        output = self.fc(lstm_out)  # (batch, 17, 17) → sai!\n","        return output[:, :, 0]  # ❌ SAI CẤU TRÚC\n","\n","# Sửa lại: dùng Dense layer đơn giản (vì input không phải chuỗi thực)\n","class DenseDemandRecovery(nn.Module):\n","    def __init__(self, input_size=41, hidden_size=128, output_size=17):\n","        super(DenseDemandRecovery, self).__init__()\n","        self.net = nn.Sequential(\n","            nn.Linear(input_size, hidden_size),\n","            nn.ReLU(),\n","            nn.Linear(hidden_size, hidden_size),\n","            nn.ReLU(),\n","            nn.Linear(hidden_size, output_size)\n","        )\n","\n","    def forward(self, x):\n","        return self.net(x)\n","\n","# Dùng mô hình Dense thay vì LSTM (vì input là vector, không phải chuỗi thời gian)\n","model = DenseDemandRecovery(input_size=41, hidden_size=128, output_size=17)\n","\n","# 4. Huấn luyện\n","criterion = nn.MSELoss()\n","optimizer = optim.Adam(model.parameters(), lr=0.001)\n","\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","model.to(device)\n","\n","epochs = 50\n","train_losses = []\n","val_losses = []\n","\n","for epoch in range(epochs):\n","    model.train()\n","    total_train_loss = 0\n","    for x_batch, y_batch in train_loader:\n","        x_batch, y_batch = x_batch.to(device), y_batch.to(device)\n","        optimizer.zero_grad()\n","        y_pred = model(x_batch)\n","        loss = criterion(y_pred, y_batch)\n","        loss.backward()\n","        optimizer.step()\n","        total_train_loss += loss.item()\n","\n","    model.eval()\n","    total_val_loss = 0\n","    with torch.no_grad():\n","        for x_batch, y_batch in val_loader:\n","            x_batch, y_batch = x_batch.to(device), y_batch.to(device)\n","            y_pred = model(x_batch)\n","            loss = criterion(y_pred, y_batch)\n","            total_val_loss += loss.item()\n","\n","    avg_train_loss = total_train_loss / len(train_loader)\n","    avg_val_loss = total_val_loss / len(val_loader)\n","    train_losses.append(avg_train_loss)\n","    val_losses.append(avg_val_loss)\n","\n","    if (epoch + 1) % 10 == 0:\n","        print(f\"Epoch {epoch+1}/{epochs}, Train Loss: {avg_train_loss:.4f}, Val Loss: {avg_val_loss:.4f}\")\n","\n","# 5. Đánh giá Decoupling Score (ρDS) — phiên bản đơn giản\n","model.eval()\n","with torch.no_grad():\n","    y_pred_scaled = model(X_tensor.to(device)).cpu().numpy()\n","\n","# Đảo chuẩn hóa để có giá trị demand thật\n","y_pred = scaler_y.inverse_transform(y_pred_scaled)\n","\n","# Tính stockout ratio theo product-store\n","# Vì dùng sample nhỏ, ta giả lập: lấy stockout rate từ dữ liệu gốc\n","stockout_ratios = []\n","demands = []\n","\n","for i, (_, row) in enumerate(df_sample.iterrows()):\n","    stock_6_22 = np.array(row['hours_stock_status'])[6:23]\n","    stockout_ratio = (stock_6_22 == 0).mean()\n","    avg_demand = y_pred[i].mean()\n","\n","    stockout_ratios.append(stockout_ratio)\n","    demands.append(avg_demand)\n","\n","from scipy.stats import pearsonr\n","rho_ds, _ = pearsonr(stockout_ratios, demands)\n","print(f\"\\n=== Đánh giá ===\")\n","print(f\"Decoupling Score (ρDS): {rho_ds:.3f}\")\n","print(\"→ Giá trị gần 0 = mô hình tách được demand khỏi stockout (tốt)\")\n","print(\"→ Giá trị âm mạnh = demand vẫn bị ảnh hưởng bởi stockout (xấu)\")\n","\n","# 6. Vẽ loss curve\n","plt.figure(figsize=(8, 4))\n","plt.plot(train_losses, label=\"Train Loss\")\n","plt.plot(val_losses, label=\"Val Loss\")\n","plt.title(\"Training Loss\")\n","plt.xlabel(\"Epoch\")\n","plt.ylabel(\"MSE Loss\")\n","plt.legend()\n","plt.grid(True)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":573},"id":"zL41YgMUgJK0","executionInfo":{"status":"ok","timestamp":1763478401010,"user_tz":-420,"elapsed":22323,"user":{"displayName":"Tri Huynh","userId":"03244751285998314177"}},"outputId":"d80a6b0f-c4bc-4108-ec8b-150a01e4bf7a"},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 10/50, Train Loss: 0.0343, Val Loss: 0.0240\n","Epoch 20/50, Train Loss: 0.0138, Val Loss: 0.0132\n","Epoch 30/50, Train Loss: 0.0093, Val Loss: 0.0110\n","Epoch 40/50, Train Loss: 0.0070, Val Loss: 0.0099\n","Epoch 50/50, Train Loss: 0.0059, Val Loss: 0.0093\n","\n","=== Đánh giá ===\n","Decoupling Score (ρDS): 0.130\n","→ Giá trị gần 0 = mô hình tách được demand khỏi stockout (tốt)\n","→ Giá trị âm mạnh = demand vẫn bị ảnh hưởng bởi stockout (xấu)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Cell: Task 2 - Censoring-Robust Demand Forecasting\n","\n","import pandas as pd\n","import numpy as np\n","import torch\n","from sklearn.preprocessing import StandardScaler\n","\n","print(\"=== BƯỚC 2: DỰ BÁO NHU CẦU 7 NGÀY TIẾP THEO ===\\n\")\n","\n","# 1. Tạo dữ liệu daily aggregate từ latent demand\n","df_sample['daily_demand'] = df_sample.apply(\n","    lambda row: np.array(row['hours_sale'])[6:23].sum(), axis=1\n",")\n","\n","# 2. Tạo target: demand 7 ngày tới (giả lập)\n","# Trong thực tế, bạn sẽ dùng window sliding\n","y_forecast = []\n","for i in range(len(df_sample) - 7):\n","    y_forecast.append(df_sample.iloc[i+7]['daily_demand'])\n","\n","# 3. Tạo features: historical demand, discount, weather, holiday\n","X_forecast = []\n","for i in range(len(df_sample) - 7):\n","    row = df_sample.iloc[i]\n","    features = [\n","        row['discount'],\n","        row['precpt'],\n","        row['holiday_flag'],\n","        row['avg_temperature'],\n","        row['avg_humidity'],\n","        row['avg_wind_level']\n","    ]\n","    X_forecast.append(features)\n","\n","X_forecast = np.array(X_forecast)\n","y_forecast = np.array(y_forecast)\n","\n","print(f\"X_forecast shape: {X_forecast.shape}\")\n","print(f\"y_forecast shape: {y_forecast.shape}\")\n","\n","# 4. Chuẩn hóa\n","scaler_X_f = StandardScaler()\n","X_forecast_scaled = scaler_X_f.fit_transform(X_forecast)\n","\n","scaler_y_f = StandardScaler()\n","y_forecast_scaled = scaler_y_f.fit_transform(y_forecast.reshape(-1, 1)).flatten()\n","\n","# 5. Huấn luyện mô hình đơn giản (Linear Regression)\n","from sklearn.linear_model import LinearRegression\n","model_forecast = LinearRegression()\n","model_forecast.fit(X_forecast_scaled, y_forecast_scaled)\n","\n","# 6. Dự báo\n","y_pred_scaled = model_forecast.predict(X_forecast_scaled)\n","y_pred = scaler_y_f.inverse_transform(y_pred_scaled.reshape(-1, 1)).flatten()\n","\n","# 7. Đánh giá\n","from sklearn.metrics import mean_absolute_error, mean_squared_error\n","mae = mean_absolute_error(y_forecast, y_pred)\n","mse = mean_squared_error(y_forecast, y_pred)\n","print(f\"\\nMAE: {mae:.4f}\")\n","print(f\"MSE: {mse:.4f}\")\n","\n","# 8. So sánh với raw sales (không dùng latent demand)\n","y_raw = df_sample['sale_amount'].iloc[7:].values  # giả lập raw sales\n","mae_raw = mean_absolute_error(y_forecast, y_raw)\n","print(f\"MAE (raw sales): {mae_raw:.4f}\")\n","print(f\"Improvement: {(mae_raw - mae) / mae_raw:.2%}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LMiBUN-zhOFp","executionInfo":{"status":"ok","timestamp":1763478661958,"user_tz":-420,"elapsed":1220,"user":{"displayName":"Tri Huynh","userId":"03244751285998314177"}},"outputId":"37982260-1b1e-4d3e-cc2c-d984929de288"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["=== BƯỚC 2: DỰ BÁO NHU CẦU 7 NGÀY TIẾP THEO ===\n","\n","X_forecast shape: (993, 6)\n","y_forecast shape: (993,)\n","\n","MAE: 0.6893\n","MSE: 1.2277\n","MAE (raw sales): 0.0215\n","Improvement: -3113.65%\n"]}]}]}